{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://getdraft-api.onrender.com/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://getdraft-api.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "89884BGNZR"
      }
    }
  }
}
