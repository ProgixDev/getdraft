# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# Prisma / Postgres (Supabase connection strings) — REQUIRED, the app
# won't boot without these. DATABASE_URL = pooled (PgBouncer) connection
# used at runtime; DIRECT_URL = direct connection for migrations /
# `prisma db execute`. Both from Supabase → Project Settings → Database.
DATABASE_URL=postgresql://postgres:[password]@...pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:[password]@...supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Email — Resend HTTP API is the PREFERRED transport (works on hosts that
# block outbound SMTP, e.g. Render). When RESEND_API_KEY is set it is used
# instead of SMTP. Get it at resend.com; MAIL_FROM must be a Resend-verified
# sender (onboarding@resend.dev works for testing, your domain for prod).
RESEND_API_KEY=

# Email (SMTP fallback) — used when RESEND_API_KEY is unset. backend owns OTP
# delivery via nodemailer.
# Works with any provider: Gmail, SendGrid, Resend SMTP relay, Mailgun, SES, etc.
# For Gmail: enable 2FA on the account, generate an App Password at
# https://myaccount.google.com/apppasswords, paste it into SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=app-password-here
MAIL_FROM=GetDraft <you@example.com>

# Signed verification token used between /auth/email/verify-otp (or
# /auth/phone/verify-otp) and /auth/complete-signup.
# Generate with: openssl rand -base64 48
AUTH_VERIFICATION_SECRET=

# Twilio Verify — SMS + WhatsApp OTPs for the phone signup path.
# Sign up at twilio.com (free trial credit). Console → Verify →
# Services → create one called "GetDraft Verify" → copy its SID.
#
# Auth options (use API Key, NOT raw Auth Token, for production):
#   1. Account SID + API Key SID + API Key Secret (preferred)
#   2. Account SID + Auth Token (simpler but full-access; OK for dev)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional fallback when no API Key is set:
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Test phones (E.164, comma-separated) — completeSignup will delete
# any prior user holding the same number before creating the new one,
# so the same phone can be used for unlimited signups during testing.
# Leave empty in production.
TEST_PHONES=

# Didit KYC — every signup completes a Custom KYC workflow (OCR +
# liveness + face match) before reaching the tabs. Sign up at
# didit.me, then copy your API key. The default workflow_id is the
# uuid of "Custom KYC" in your Didit dashboard.
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
# Shared secret used to verify the X-Signature header on Didit
# webhooks. Get this from Didit dashboard → Webhooks. When unset,
# signature checks are skipped (dev only — production must set this).
DIDIT_WEBHOOK_SECRET=
# Where Didit redirects after verification when the client doesn't
# pass its own deep-link. In dev this can be an ngrok tunnel URL so
# the hosted landing page is publicly reachable. In production: the
# Render backend URL.
PUBLIC_BACKEND_URL=

# Guardian linking — HMAC secret that signs the QR tokens athletes
# show to their parents. Falls back to JWT_SECRET when unset.
# Generate with: openssl rand -base64 48
GUARDIAN_QR_SECRET=

# App
FRONTEND_URL=getdraft://
CORS_ORIGINS=*
