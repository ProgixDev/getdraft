# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Email (custom SMTP) — backend owns OTP delivery via nodemailer.
# Works with any provider: Gmail, SendGrid, Resend SMTP relay, Mailgun, SES, etc.
# For Gmail: enable 2FA on the account, generate an App Password at
# https://myaccount.google.com/apppasswords, paste it into SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=app-password-here
MAIL_FROM=GetDraft <you@example.com>

# Signed verification token used between /auth/email/verify-otp and
# /auth/complete-signup. Generate with: openssl rand -base64 48
AUTH_VERIFICATION_SECRET=

# Twilio Verify — SMS + WhatsApp OTPs for the phone signup path.
# Sign up at twilio.com (free trial credit). Console → Verify →
# Services → create one called "GetDraft Verify" → copy its SID.
# For dev cost-free testing, swap in Test Credentials from
# Console → Settings → API keys → Test Credentials.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App
FRONTEND_URL=getdraft://
CORS_ORIGINS=*
