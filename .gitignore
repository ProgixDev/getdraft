# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
.backend.log
.expo.log

# macOS
.DS_Store
._*

# Vim
*.swp
*.swo
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Local MCP config — contains credentials, never commit
.mcp.json

# Local Claude Code settings
.claude/

# Reports & doc artifacts — keep markdown and PDF deliverables out of the repo.
# Already-tracked files are unaffected (git keeps tracking them); this only
# stops NEW .md/.pdf from being added. Force one in with `git add -f <file>`.
*.md
*.pdf
