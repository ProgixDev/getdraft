{
  "expo": {
    "name": "getdraft",
    "slug": "getdraft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "getdraft",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.achrefdev.getdraft",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "GetDraft needs access to your photos so you can showcase your athletic profile and add highlight reels.",
        "NSPhotoLibraryAddUsageDescription": "GetDraft saves selected photos to your profile.",
        "NSCameraUsageDescription": "GetDraft uses the camera to capture profile photos, scan guardian QR codes, and record your guardian declaration video.",
        "NSMicrophoneUsageDescription": "GetDraft uses the microphone to record your guardian declaration video."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.achrefdev.getdraft"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "GetDraft needs access to your photos so you can showcase your athletic profile and add highlight reels.",
          "cameraPermission": "GetDraft uses the camera to capture profile photos and highlight clips."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GetDraft uses the camera to scan QR codes for guardian linking and to record your guardian declaration video.",
          "microphonePermission": "GetDraft uses the microphone to record your guardian declaration video.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "abdfc897-1a97-4964-85a2-90428a10ca4d"
      },
      "supabaseUrl": "https://vgrlyodnkvouweywzevc.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZncmx5b2Rua3ZvdXdleXd6ZXZjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc3MTM3NDUsImV4cCI6MjA5MzI4OTc0NX0.GFuQNfbGC1UCz06sG3gqOJqyAcaKDSsMuJ5ZzN2_Ys8",
      "stripePublishableKey": "pk_test_51TVSj4RxpA5KOrrI4p1A7H6IFU1lB9oqeoR2TUJsy4ofEcqJtou3GXLAer3tl6JO1MoJudupbHGqbmEOxxBbTDKD00os6ktadq"
    },
    "owner": "achrefdev"
  }
}
